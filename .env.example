# ═══════════════════════════════════════════════════════════════════════════
# ASTRA-M CodeSearch — переменные читает только config.py (см. там же дефолты)
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM
# ─────────────────────────────────────────────────────────────────────────────

# Токен бота от @BotFather
# Как получить: 1) Откройте @BotFather в Telegram 2) /newbot 3) скопируйте токен
TELEGRAM_BOT_TOKEN=

# Список разрешённых пользователей (Telegram user_id через запятую)
# Как узнать свой user_id: напишите @userinfobot в Telegram
# Пустое значение = доступ для всех (не рекомендуется для продакшена)
# Пример: 123456789,987654321
TELEGRAM_WHITELIST_USERS=

# ─────────────────────────────────────────────────────────────────────────────
# OPENROUTER (LLM API)
# ─────────────────────────────────────────────────────────────────────────────

# Базовый URL API OpenRouter (обычно не меняется)
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# API ключ от openrouter.ai
# Как получить: 1) Зарегистрируйтесь на openrouter.ai 2) Settings → Keys → Create Key
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# EMBEDDINGS (Векторные представления)
# ─────────────────────────────────────────────────────────────────────────────

# Модель для создания эмбеддингов (через OpenRouter)
# Рекомендуемые модели:
#   - openai/text-embedding-3-small (1536 размерность, дешёвый)
#   - openai/text-embedding-3-large (3072 размерность, качественнее)
#   - qwen/qwen3-embedding-8b (4096 размерность, open-source)
EMBEDDINGS_MODEL=openai/text-embedding-3-small

# Размерность векторов (должна совпадать с моделью!)
# text-embedding-3-small: 1536
# text-embedding-3-large: 3072
# qwen3-embedding-8b: 4096
EMBEDDINGS_DIMENSION=1536

# Макс. символов в одном батче для эмбеддингов (~4 символа ≈ 1 токен)
# Большие файлы разбиваются на батчи. Увеличьте для ускорения, уменьшите при 413 ошибках.
EMBED_MAX_CHARS_PER_BATCH=8000

# Макс. параллельных запросов к API эмбеддингов
# Увеличьте для ускорения индексации, уменьшите при rate limiting
EMBED_MAX_CONCURRENT=10

# Макс. параллельно обрабатываемых файлов
# Увеличьте для ускорения индексации на мощных серверах
EMBED_MAX_FILES_CONCURRENT=5

# Таймаут HTTP-запроса для эмбеддингов (секунды)
# Увеличьте при медленном интернете или больших файлах
EMBED_REQUEST_TIMEOUT=60

# ─────────────────────────────────────────────────────────────────────────────
# QDRANT (Векторная база данных)
# ─────────────────────────────────────────────────────────────────────────────

# URL Qdrant сервера
# Локально: http://localhost:6333
# Удалённо: https://your-qdrant-instance.com
QDRANT_URL=https://qdrant.gotskin.ru

# Только Docker Compose: URL Qdrant для контейнера astra-m (перекрывает QDRANT_URL из env_file).
# Не задано → http://qdrant:6333 (сервис qdrant в docker-compose). Внешний инстанс: https://...
# QDRANT_DOCKER_URL=

# API ключ для Qdrant (если требуется аутентификация)
# Пустое значение = без аутентификации
QDRANT_API_KEY=

# Размер батча для upsert в Qdrant
# Увеличьте для ускорения индексации, уменьшите при 413 ошибках от nginx
QDRANT_UPSERT_BATCH_SIZE=200

# ─────────────────────────────────────────────────────────────────────────────
# ПУТЬ К КАТАЛОГУ С РЕПОЗИТОРИЯМИ (список репо не в .env — Qdrant / UI)
# ─────────────────────────────────────────────────────────────────────────────

# Базовый путь к каталогу с клонами репозиториев (скан кандидатов, пути в карточках репо)
# Список подключённых репозиториев хранится в Qdrant / Web UI, не в .env
REPOS_BASE_PATH=d:/astra-m-project

# Макс. размер файла в байтах (больше — плейсхолдер вместо содержимого)
# Превышение = файл индексируется как "слишком большой" без содержимого
FILE_MAX_SIZE=2000000

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# Количество последних сессий в logs/ (ротация)
# Старые логи удаляются автоматически
LOG_ROTATION=10

# ─────────────────────────────────────────────────────────────────────────────
# RAG (simple-ветка Telegram и веб: rag_mode в GET/PUT /api/config)
# ─────────────────────────────────────────────────────────────────────────────

# Модель LLM для одноагентного режима (через OpenRouter).
# Дефолт в коде (если переменная не задана): google/gemini-2.5-flash-preview
# Примеры:
#   - google/gemini-2.5-flash-preview
#   - google/gemini-2.0-flash-001
#   - openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.5-flash-preview

# Режим при Simple в Telegram и начальный rag_mode в вебе: simple | agent
# simple — один проход; agent — generator.py (в вебе Two-Agent нет, только в Telegram)
# Дефолт в коде: agent
RAG_RUNTIME_MODE=agent

# Макс. итераций агентного цикла (поиск → LLM → tool_call → ...)
# Дефолт в коде: 10
RAG_AGENT_MAX_ITERATIONS=10

# Макс. символов чанка в ответе поиска (0 = передавать целиком)
# Увеличьте для больших файлов, уменьшите для экономии токенов
RAG_CHUNK_DISPLAY_CHARS=1000

# Топ-K результатов по умолчанию при поиске (агент / инструменты)
# Дефолт в коде: 10
RAG_SEARCH_TOP_K=10

# Верхняя граница top_k (LLM не может запросить больше)
# Ограничивает макс. количество результатов поиска
RAG_SEARCH_TOP_K_MAX=15

# Порог релевантности (score) для включения результата (0-1)
# 0 = брать все результаты, 0.5 = только релевантные, 0.8 = только очень точные
RAG_MIN_SCORE=0.5

# Макс. результатов при поиске по всем репо (объединённый топ)
# Ограничивает общее количество результатов из всех репозиториев
RAG_SEARCH_ALL_LIMIT=15

# max_tokens в цикле агента (с tool_calls)
# Дефолт в коде: 10000
RAG_AGENT_MAX_TOKENS=10000

# max_tokens для финального ответа (без инструментов)
# Дефолт в коде: 3000
RAG_AGENT_FINAL_MAX_TOKENS=3000

# temperature для LLM (0–1)
# Дефолт в коде: 0.1
RAG_AGENT_TEMPERATURE=0.1

# Таймаут HTTP-запросов к OpenRouter (секунды)
# Увеличьте при медленном интернете или сложных запросах
RAG_AGENT_TIMEOUT=60

# Длина превью результата tool_call в session log
# Для отладки: сколько символов логировать
RAG_LOG_RESULT_PREVIEW_LEN=300

# ─────────────────────────────────────────────────────────────────────────────
# SIMPLE MODE: QUERY REWRITING
# Переписывание запроса пользователя в технические ключевые слова
# перед векторным поиском (улучшает точность поиска)
# ─────────────────────────────────────────────────────────────────────────────

# Модель для Query Rewriting в Simple режиме (через OpenRouter)
# Должна быть максимально быстрой и дешёвой — только извлечение ключевых слов
# Рекомендуемые модели:
#   - google/gemini-2.5-flash (быстрый, дешёвый — рекомендуется)
#   - meta-llama/llama-3.1-8b-instruct (опенсорс, очень дёшево)
SIMPLE_REWRITE_MODEL=google/gemini-2.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# TWO-AGENT PIPELINE (Двухагентный режим)
# Используется когда USE_TWO_AGENT_PIPELINE=true
# ─────────────────────────────────────────────────────────────────────────────

# Дефолт для Telegram: Two-Agent vs Simple (команда /mode переключает в памяти до рестарта)
# true = Analyst + Answerer (rag/agent/pipeline)
# false = «простой» режим: дальше смотри RAG_RUNTIME_MODE (simple или agent)
USE_TWO_AGENT_PIPELINE=true

# ─────────────────────────────────────────────────────────────────────────────
# ANALYST (Аналитик - планировщик поиска)
# Быстрая/дешёвая модель — только генерирует поисковые запросы, НЕ читает код
# ─────────────────────────────────────────────────────────────────────────────

# Модель для Analyst (через OpenRouter)
# Рекомендуемые модели:
#   - google/gemini-2.5-flash (быстрый, дешёвый — рекомендуется)
#   - meta-llama/llama-3.1-8b-instruct (опенсорс, очень дёшево)
ANALYST_MODEL=google/gemini-2.5-flash

# temperature для Analyst (0–1)
# 0.1-0.3 = детерминированный анализ
# 0.4-0.6 = более вариативные поисковые запросы
ANALYST_TEMPERATURE=0.3

# max_tokens для Analyst
# 1500-2000 = достаточно для JSON ответа с 3-5 запросами
ANALYST_MAX_TOKENS=2000

# Таймаут для Analyst (секунды)
# Анализ обычно быстрый, но увеличьте при медленном API
ANALYST_TIMEOUT=60

# Макс. сообщений истории для Analyst
# Analyst видит последние N сообщений диалога
ANALYST_HISTORY_LIMIT=20

# ─────────────────────────────────────────────────────────────────────────────
# ANSWERER (Эксперт - синтез ответа)
# "Думающая" модель — читает сырые чанки кода и формирует финальный ответ
# ─────────────────────────────────────────────────────────────────────────────

# Модель для Answerer (через OpenRouter)
# Рекомендуемые модели:
#   - openai/o3-mini (думающая, быстрая — рекомендуется)
#   - anthropic/claude-3.7-sonnet (высокое качество)
#   - google/gemini-2.5-pro-preview (максимальное качество)
ANSWERER_MODEL=openai/o3-mini

# temperature для Answerer (0–1)
# 0.1-0.2 = детерминированные ответы (рекомендуется)
# 0.3-0.5 = более вариативные формулировки
ANSWERER_TEMPERATURE=0.1

# max_tokens для Answerer (финальный ответ пользователю)
# 3000-5000 = достаточно для развёрнутого ответа
ANSWERER_MAX_TOKENS=4000

# Лимит токенов на "раздумья" COT-моделей (o3-mini, claude-3.7-sonnet и др.)
# max_completion_tokens = ANSWERER_MAX_TOKENS + ANSWERER_MAX_REASONING_TOKENS
# 0 = не ограничивать раздумья (не рекомендуется — может ждать очень долго)
# 1000-3000 = баланс качества и скорости
ANSWERER_MAX_REASONING_TOKENS=2000

# Таймаут для Answerer (секунды)
# Думающие модели могут работать дольше — увеличьте при таймаутах
ANSWERER_TIMEOUT=120

# Макс. сообщений истории для Answerer
ANSWERER_HISTORY_LIMIT=20

# ─────────────────────────────────────────────────────────────────────────────
# PIPELINE (Настройки пайплайна)
# ─────────────────────────────────────────────────────────────────────────────

# Макс. итераций поиска (Analyst → Search → Answerer → цикл)
# 2-3 = обычно достаточно
# 4-5 = для глубокого ресёрча сложных вопросов
# Итерации теперь быстрее (нет шага суммаризации)
PIPELINE_MAX_ITERATIONS=4