# ═══════════════════════════════════════════════════════════════════════════
# АСТРА-М (ASTRA-M) — RAG по кодовой базе
#
# КАК ПОЛЬЗОВАТЬСЯ ЭТИМ ФАЙЛОМ
# ─────────────────────────────
# 1) Скопируйте в ".env" рядом с проектом:  cp .env.example .env  (или вручную).
# 2) Заполните секреты (OPENAI_API_KEY, при необходимости QDRANT_API_KEY).
# 3) Подставьте свои пути и URL. Остальное можно не трогать — значения совпадают
#    с дефолтами в config.py (если переменная в .env отсутствует, подставится код).
# 4) Строки с # в начале — закомментированы; раскомментируйте при необходимости.
#
# Про «больше / меньше»: для чисел речь о направлении изменения относительно текущего
# значения, а не о «правильном» диапазоне — ориентируйтесь на лимиты API и железа.
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# LLM — единая точка входа к моделям (OpenAI-compatible: OpenRouter, vLLM, Azure, корп. прокси)
# ─────────────────────────────────────────────────────────────────────────────

# OPENAI_BASE_URL
#   Смысл: корень HTTP API без суффикса /chat/completions (как в OpenAI SDK).
#   Примеры: https://openrouter.ai/api/v1 | http://localhost:8000/v1
#   Неверный URL: 404/connection errors при любых запросах к LLM и эмбеддингам.
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# OPENAI_API_KEY
#   Смысл: секрет провайдера; без него большинство облачных API вернёт 401.
#   Храните только в .env, не коммитьте. Пустая строка = запросы без заголовка (редко нужно).
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# EMBEDDINGS — векторизация текста при индексации и при поиске
# (тот же OPENAI_BASE_URL и OPENAI_API_KEY, что и для чата)
# ─────────────────────────────────────────────────────────────────────────────

# EMBEDDINGS_MODEL
#   Смысл: идентификатор модели эмбеддингов на вашем endpoint.
#   Важно: после смены модели коллекцию в Qdrant нужно переиндексировать — размерность
#   и «геометрия» векторов меняются, старые точки несовместимы с новыми.
#   Типичные пары с EMBEDDINGS_DIMENSION: small→1536, large→3072, qwen3-8b→4096.
EMBEDDINGS_MODEL=openai/text-embedding-3-small

# EMBEDDINGS_DIMENSION
#   Смысл: длина вектора (должна совпадать с выбранной моделью и с настройкой коллекции Qdrant).
#   Диапазон по моделям: обычно 1536 / 3072 / 4096 — смотрите документацию модели.
#   Неверное число: ошибки при upsert/search или мусор в поиске.
#   Больше (если модель поддерживает): часто лучше семантика, дороже запрос и хранение.
#   Меньше: дешевле и быстрее, но не подставляйте «меньше» произвольно — только если модель такая.
EMBEDDINGS_DIMENSION=1536

# EMBED_MAX_CHARS_PER_BATCH
#   Смысл: сколько символов текста отправлять одним запросом на эмбеддинги (длинные файлы режутся).
#   Диапазон ориентировочно: 2000–32000; упирается в лимит токенов модели и таймаут.
#   Больше: меньше HTTP-запросов при индексации, быстрее общий прогон; риск 413/timeout на стороне прокси/API.
#   Меньше: стабильнее на слабом канале и жёстких лимитах, но медленнее индексация.
EMBED_MAX_CHARS_PER_BATCH=8000

# EMBED_MAX_CONCURRENT
#   Смысл: сколько параллельных HTTP-запросов к API эмбеддингов допускается одновременно.
#   Диапазон: 1–50+ в зависимости от rate limit провайдера и вашей сети.
#   Больше: быстрее индексация больших деревьев; риск 429 Too Many Requests и нестабильности.
#   Меньше: медленнее, но предсказуемее при жёстких квотах.
EMBED_MAX_CONCURRENT=10

# EMBED_MAX_FILES_CONCURRENT
#   Смысл: сколько файлов обрабатывать параллельно на уровне пайплайна (внутри — свои батчи эмбеддингов).
#   Диапазон: 1–20; упирается в CPU, диск и тот же API.
#   Больше: лучше утилизация на многоядерной машине; выше пик RAM и нагрузка на диск.
#   Меньше: спокойнее для ноутбука и сетевых лимитов.
EMBED_MAX_FILES_CONCURRENT=5

# EMBED_REQUEST_TIMEOUT
#   Смысл: секунды ожидания ответа на один запрос эмбеддингов.
#   Диапазон: 30–300; для очень больших батчей или медленного API — к верхней границе.
#   Больше: реже ложные обрывы на долгих ответах.
#   Меньше: быстрее «падает» запрос при зависании; может понадобиться уменьшить EMBED_MAX_CHARS_PER_BATCH.
EMBED_REQUEST_TIMEOUT=60

# ─────────────────────────────────────────────────────────────────────────────
# QDRANT — хранение векторов и метаданных чанков
# ─────────────────────────────────────────────────────────────────────────────

# QDRANT_URL
#   Смысл: HTTP(S) адрес REST API Qdrant (порт обычно 6333 для HTTP).
#   Локально: http://localhost:6333 | облако: https://… как выдал хостинг.
#   Неверный хост: индексация и поиск не работают.
QDRANT_URL=https://qdrant.yoursite.ru

# QDRANT_API_KEY
#   Смысл: ключ, если на сервере включена аутентификация; для локального docker без auth — пусто.
#   Пустая строка: клиент не шлёт ключ (типичный локальный режим).
QDRANT_API_KEY=

# QDRANT_UPSERT_BATCH_SIZE
#   Смысл: сколько точек (чанков) вставлять/обновлять за один запрос к Qdrant.
#   Диапазон: 50–500 типично; сверху часто упираетесь в nginx 413 или лимит тела запроса.
#   Больше: меньше round-trip при массовой загрузке, быстрее индексация.
#   Меньше: безопаснее при прокси с малым client_max_body_size и нестабильной сети.
QDRANT_UPSERT_BATCH_SIZE=200

# ─────────────────────────────────────────────────────────────────────────────
# REPOSITORIES — где на диске лежат клонируемые репозитории для индексации
# ─────────────────────────────────────────────────────────────────────────────

# REPOS_BASE_PATH
#   Смысл: корневая папка, внутри которой лежат подпапки с именами репозиториев.
#   Формат: абсолютный путь; Windows: d:/projects, Linux: /home/user/projects.
#   Неверный путь: индексация и открытие файлов в UI не найдут исходники.
REPOS_BASE_PATH=d:/projects

# REPOS_WHITELIST
#   Смысл: перечень имён подпапок под REPOS_BASE_PATH через запятую (без пробелов или с пробелами — обрежутся strip).
#   Использование: ориентир для README/команды; выбор репо в приложении задаётся также через UI.
#   Пусто: список в конфиге пустой — смотрите интерфейс добавления репозиториев.
#   Пример: backend,frontend,services-pdf
REPOS_WHITELIST=backend,frontend,services-pdf

# FILE_MAX_SIZE
#   Смысл: максимальный размер одного файла в байтах, для которого читается содержимое при индексации.
#   Диапазон: 100_000 (100KB) … 50_000_000+ в зависимости от RAM и политики.
#   Больше: в индекс попадают крупные файлы (бинарники, сгенерированные артефакты) — шум и затраты.
#   Меньше: большие файлы заменяются плейсхолдером — меньше токенов, но нет содержимого в поиске.
FILE_MAX_SIZE=2000000

# ─────────────────────────────────────────────────────────────────────────────
# RAG_RUNTIME_MODE — режим ответа в веб-чате (стартовое значение; в UI можно сменить без правки .env)
# ─────────────────────────────────────────────────────────────────────────────

# RAG_RUNTIME_MODE
#   Смысл: какой пайплайн по умолчанию включён при открытии приложения.
#   Допустимые значения: simple | agent (любое другое в коде сбрасывается на agent).
#   simple: быстрее и дешевле — переписывание запроса + векторный поиск + ответ (см. SIMPLE_REWRITE_MODEL).
#   agent: цикл «LLM ↔ инструменты (поиск по коду)» — глубже, дороже по токенам.
#   Переключение в runtime: через API/UI (см. README), переменная задаёт только дефолт при старте.
RAG_RUNTIME_MODE=agent

# ─────────────────────────────────────────────────────────────────────────────
# SIMPLE MODE — Query Rewriting (только для RAG_RUNTIME_MODE=simple)
# ─────────────────────────────────────────────────────────────────────────────

# SIMPLE_REWRITE_MODEL
#   Смысл: маленькая быстрая модель: превращает вопрос пользователя в короткие ключевые фразы для поиска.
#   Не нужна «умная» модель — важны скорость и низкая цена; качество основного ответа задаёт другой путь.
#   Смена модели: влияет только на форму запроса к векторному поиску, не на размерность эмбеддингов.
SIMPLE_REWRITE_MODEL=google/gemini-2.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# RAG AGENT — одноагентный режим (когда USE_TWO_AGENT_PIPELINE=false)
# OPENAI_MODEL здесь — основной «мозг» цикла с tool calls.
# ─────────────────────────────────────────────────────────────────────────────

# OPENAI_MODEL
#   Смысл: модель для агентного цикла: решает, какие запросы к semantic_search сделать, собирает ответ.
#   Выбор: баланс цены/качества; слабая модель — хуже стратегия поиска и формулировки.
#   Не путать с ANALYST_MODEL/ANSWERER_MODEL — они используются в двухагентном режиме.
OPENAI_MODEL=google/gemini-2.5-flash-preview

# RAG_AGENT_MAX_ITERATIONS
#   Смысл: максимум шагов «ответ модели → вызов инструмента → снова модель» за один пользовательский запрос.
#   Диапазон: 1–20; слишком мало — обрыв до полного ответа; слишком много — долго и дорого.
#   Больше: глубже многошаговый ресёрч, риск зацикливания и перерасход токенов.
#   Меньше: быстрее и дешевле; возможен обрезанный ответ на сложных задачах.
RAG_AGENT_MAX_ITERATIONS=10

# RAG_CHUNK_DISPLAY_CHARS
#   Смысл: обрезка текста чанка, передаваемого в контекст модели после поиска; 0 = не обрезать (полный content).
#   Диапазон: 0 или 500–8000+; ограничивает размер контекста и стоимость.
#   Больше (или 0): модель видит больше кода — точнее цитаты, выше счёт токенов.
#   Меньше: дешевле и короче контекст; можно потерять детали в длинных файлах.
RAG_CHUNK_DISPLAY_CHARS=0

# RAG_SEARCH_TOP_K
#   Смысл: сколько ближайших чанков возвращать по умолчанию при вызове semantic_search инструментом.
#   Диапазон: 1–RAG_SEARCH_TOP_K_MAX (логически не больше потолка ниже).
#   Больше: шире охват, больше шума и токенов в контексте.
#   Меньше: уже выдача, дешевле; можно пропустить релевантный фрагмент.
RAG_SEARCH_TOP_K=10

# RAG_SEARCH_TOP_K_MAX
#   Смысл: жёсткий потолок: модель не сможет запросить top_k больше этого числа (защита от перегруза).
#   Диапазон: >= RAG_SEARCH_TOP_K, типично 10–30.
#   Больше: разрешает «широкий» поиск по запросу LLM; выше нагрузка и токены.
#   Меньше: ужесточает лимит даже если модель просит больше чанков.
RAG_SEARCH_TOP_K_MAX=15

# RAG_MIN_SCORE
#   Смысл: порог косинусной близости (и аналогов) в [0..1]: ниже — отбрасываем чанк.
#   Диапазон: 0.0–1.0. В коде 0 = «брать всё, что вернул поиск» (фильтр по score отключён).
#   Больше: строже отбор — меньше шума, выше риск пустой выдачи по редким запросам.
#   Меньше: мягче фильтр — больше кандидатов, возможен мусор в контексте.
RAG_MIN_SCORE=0.55

# RAG_SEARCH_ALL_LIMIT
#   Смысл: максимум чанков при объединённом поиске «по всем репозиториям» (агрегированный топ).
#   Диапазон: 5–50 ориентировочно.
#   Больше: богаче контекст при кросс-репо запросах; тяжелее промпт.
#   Меньше: дешевле и короче ответы; можно не дотянуться до нужного репо.
RAG_SEARCH_ALL_LIMIT=15

# RAG_AGENT_MAX_TOKENS
#   Смысл: лимит max_tokens на один ответ модели внутри агентного цикла (пока идут tool_calls).
#   Диапазон: 2000–128000 зависит от модели; для кода часто 4k–32k достаточно.
#   Больше: длинные рассуждения и списки вызовов; дороже и медленнее.
#   Меньше: обрыв посреди «плана» или JSON с tool_calls — рост ошибок и повторов.
RAG_AGENT_MAX_TOKENS=10000

# RAG_AGENT_FINAL_MAX_TOKENS
#   Смысл: лимит для финального сообщения пользователю без инструментов (последний шаг цикла).
#   Диапазон: 500–16000 по задаче; короткие ответы — меньше.
#   Больше: развёрнутые объяснения и большие блоки кода в ответе.
#   Меньше: короче ответы; возможен обрез по max_tokens посреди кода.
RAG_AGENT_FINAL_MAX_TOKENS=3500

# RAG_AGENT_TEMPERATURE
#   Смысл: креативность сэмплирования: 0 ≈ жёстче к наиболее вероятным токенам, 1 — разнообразнее.
#   Диапазон: 0.0–1.0 (если модель поддерживает).
#   Больше: вариативнее формулировки и иногда неожиданные tool-вызовы.
#   Меньше: стабильнее и предсказуемее для технических ответов; рекомендуется 0–0.3 для кода.
RAG_AGENT_TEMPERATURE=0.1

# RAG_AGENT_TIMEOUT
#   Смысл: таймаут HTTP к LLM в одноагентном режиме, секунды.
#   Диапазон: 30–600; тяжёлые модели и длинные контексты — ближе к верху.
#   Больше: реже обрыв на долгом размышлении модели.
#   Меньше: быстрее фейл при лагах сети — пользователь видит ошибку раньше.
RAG_AGENT_TIMEOUT=60

# RAG_LOG_RESULT_PREVIEW_LEN
#   Смысл: сколько символов результата tool_call писать в человекочитаемый лог сессии (отладка).
#   Диапазон: 0–2000+; при 0 превью в логе пустое (результат обрезается до нуля символов).
#   Больше: больше контекста в логах для отладки; тяжелее файлы logs/.
#   Меньше: компактные логи; сложнее расследовать сбои.
RAG_LOG_RESULT_PREVIEW_LEN=300

# ─────────────────────────────────────────────────────────────────────────────
# USE_TWO_AGENT_PIPELINE — переключатель архитектуры ответа (не путать с RAG_RUNTIME_MODE)
# ─────────────────────────────────────────────────────────────────────────────

# USE_TWO_AGENT_PIPELINE
#   Смысл: true — цепочка Analyst → поиск → Answerer (PIPELINE_*); false — одноагентный RAG_AGENT_*.
#   Значения-истина: true | 1 | yes (регистр не важен); всё остальное — false.
#   true: обычно качественнее за счёт двух специализированных моделей и дороже по запросам.
#   false: один LLM с инструментами — проще и часто быстрее на один вопрос.
USE_TWO_AGENT_PIPELINE=true

# ─────────────────────────────────────────────────────────────────────────────
# ANALYST — «планировщик»: формулирует поисковые запросы (дёшево, мало токенов на выход)
# ─────────────────────────────────────────────────────────────────────────────

# ANALYST_MODEL
#   Смысл: модель, которая по вопросу пользователя предлагает формулировки для семантического поиска.
#   Нужна быстрая и дешёвая; глубокое «рассуждение» здесь не требуется.
ANALYST_MODEL=google/gemini-2.5-flash

# ANALYST_TEMPERATURE
#   Смысл: разброс формулировок поисковых запросов.
#   Диапазон: 0.0–0.7 типично для JSON-плана.
#   Больше: разнообразнее запросы; риск шума и отхода от терминов кодовой базы.
#   Меньше: стабильнее и ближе к буквальным ключевым словам.
ANALYST_TEMPERATURE=0.3

# ANALYST_MAX_TOKENS
#   Смысл: потолок длины ответа аналитика (JSON с несколькими строками поиска).
#   Диапазон: 500–4000; упирается в число параллельных поисковых фраз.
#   Больше: место для длинных пояснений в JSON (если промпт разрешает).
#   Меньше: риск обрезанного JSON и ошибок парсинга.
ANALYST_MAX_TOKENS=2000

# ANALYST_TIMEOUT
#   Смысл: секунды ожидания ответа аналитика.
#   Диапазон: 20–120.
#   Больше: терпимее к медленному API.
#   Меньше: быстрее отказ при зависаниях.
ANALYST_TIMEOUT=60

# ANALYST_HISTORY_LIMIT
#   Смысл: сколько последних сообщений диалога подмешивать в контекст аналитику (срез history[-N:]).
#   Диапазон: 1–50; значение 1 — только последнее сообщение в истории, 20 — типичный баланс.
#   Больше: лучше учёт уточнений в треде; длиннее промпт и дороже.
#   Меньше: дешевле; хуже связность на длинных обсуждениях.
ANALYST_HISTORY_LIMIT=20

# ─────────────────────────────────────────────────────────────────────────────
# ANSWERER — «эксперт»: собирает финальный ответ из найденных чанков
# ─────────────────────────────────────────────────────────────────────────────

# ANSWERER_MODEL
#   Смысл: основная «тяжёлая» модель для итогового текста; может быть reasoning-моделью (o3-mini и т.д.).
#   Качество здесь сильнее влияет на полезность ответа, чем у аналитика.
ANSWERER_MODEL=openai/o3-mini

# ANSWERER_TEMPERATURE
#   Смысл: вариативность финальных формулировок и структуры ответа.
#   Диапазон: 0.0–0.5 для технической документации обычно достаточно.
#   Больше: живее язык; риск отхода от фактов из чанков.
#   Меньше: суше и ближе к цитированию источников.
ANSWERER_TEMPERATURE=0.1

# ANSWERER_MAX_TOKENS
#   Смысл: лимит длины итогового ответа (часть моделей использует max_tokens или аналог).
#   Диапазон: 1000–32000 по задаче и лимитам модели.
#   Больше: длинные разборы и большие листинги кода.
#   Меньше: короче ответы; риск обрыва.
ANSWERER_MAX_TOKENS=4000

# ANSWERER_MAX_REASONING_TOKENS
#   Смысл: для моделей с внутренним chain-of-thought — ограничение «раздумий» до выхода пользователю.
#   В коде: 0 = параметр в API не передаётся (поведение по умолчанию провайдера).
#   Диапазон: 0 или 500–8000+ для o3/r1-подобных.
#   Больше: глубже проработка сложных вопросов; дольше ответ и дороже.
#   Меньше или 0: быстрее/дешевле; у reasoning-моделей возможен недостаток «обдумывания».
ANSWERER_MAX_REASONING_TOKENS=2000

# ANSWERER_TIMEOUT
#   Смысл: таймаут на генерацию финального ответа; у тяжёлых моделей ставьте выше, чем у аналитика.
#   Диапазон: 60–600.
#   Больше: меньше таймаутов на длинных ответах.
#   Меньше: жёстче лимит ожидания для пользователя.
ANSWERER_TIMEOUT=120

# ANSWERER_HISTORY_LIMIT
#   Смысл: сколько последних сообщений диалога видит answerer при синтезе ответа (срез history[-N:]).
#   Диапазон: 1–50; смысл «больше/меньше» — как у ANALYST_HISTORY_LIMIT.
#   Больше: богаче контекст для уточнений; дороже промпт.
#   Меньше: дешевле и короче контекст.
ANSWERER_HISTORY_LIMIT=20

# ─────────────────────────────────────────────────────────────────────────────
# PIPELINE — сколько раундов «аналитик → поиск → ответчик» в двухагентном режиме
# ─────────────────────────────────────────────────────────────────────────────

# PIPELINE_MAX_ITERATIONS
#   Смысл: максимум внешних итераций пайплайна на один пользовательский запрос (глубина многошагового ресёрча).
#   Диапазон: 1–8 ориентировочно; каждая итерация — дополнительные вызовы LLM и поиска.
#   Больше: глубже разбор многочастных вопросов; сильно дороже и дольше.
#   Меньше: быстрее и дешевле; возможен неполный ответ на многоаспектные задачи.
PIPELINE_MAX_ITERATIONS=3

# ─────────────────────────────────────────────────────────────────────────────
# DESCRIBER — автоописание репозитория (POST /api/repos/{name}/describe)
# Агент с инструментами semantic_search + read_file; итог — JSON в метаданные коллекции Qdrant.
# ─────────────────────────────────────────────────────────────────────────────

# DESCRIBER_MODEL
#   Смысл: модель для обхода индекса и вызова инструментов; финальный JSON тоже она (или добор json_object).
#   Пустая строка: используется ANALYST_MODEL — тот же быстрый/дёшевый профиль, что и у планировщика.
#   Задать явно: если нужна более «литературная» выжимка или другой провайдер.
DESCRIBER_MODEL=

# DESCRIBER_MAX_ITERATIONS
#   Смысл: максимум раундов «LLM → tool_calls (поиск/чтение файла)» на один запрос describe.
#   Диапазон: 4–20; каждый раунд — дополнительные вызовы API и поиска.
#   Больше: глубже обход README/манифестов; дольше и дороже.
#   Меньше: быстрее ответ; риск неполного описания больших репо.
DESCRIBER_MAX_ITERATIONS=12

# DESCRIBER_MAX_TOKENS
#   Смысл: потолок ответа в шагах с инструментами (в т.ч. рассуждения перед вызовом тула).
#   Диапазон: 2000–16000; обычно близко к RAG_AGENT_MAX_TOKENS.
#   Больше: место для длинных планов и больших вставок из тулов в контекст.
#   Меньше: дешевле; риск обрезания перед tool_calls.
DESCRIBER_MAX_TOKENS=10000

# DESCRIBER_FINAL_MAX_TOKENS
#   Смысл: лимит финального запроса с response_format json_object (без инструментов), если нужно «добить» JSON.
#   Диапазон: 1000–4000; полные описания репозитория могут быть длинными.
#   Больше: реже обрыв на длинном full_description.
#   Меньше: короче итог; риск невалидного JSON.
DESCRIBER_FINAL_MAX_TOKENS=2500

# DESCRIBER_TEMPERATURE
#   Смысл: вариативность формулировок названия и описаний.
#   Диапазон: 0.0–0.4 для стабильных карточек репозитория.
#   Больше: разнообразнее текст; риск шума.
#   Меньше: предсказуемее и ближе к фактам из индекса.
DESCRIBER_TEMPERATURE=0.2

# DESCRIBER_TIMEOUT
#   Смысл: секунды на один HTTP-запрос к LLM в цикле Describer (как RAG_AGENT_TIMEOUT).
#   Диапазон: 30–180; тяжёлые модели или медленный endpoint — увеличьте.
#   Больше: меньше таймаутов на длинных шагах.
#   Меньше: быстрее отказ при зависаниях.
DESCRIBER_TIMEOUT=60

# ─────────────────────────────────────────────────────────────────────────────
# TLS / корпоративная сеть (опционально; использует стандартные переменные окружения Python/requests)
# ─────────────────────────────────────────────────────────────────────────────

# REQUESTS_CA_BUNDLE — путь к PEM-файлу с цепочкой доверенных CA (корпоративный MITM, свой корень).
# SSL_CERT_FILE — альтернативное имя, подхватывается OpenSSL; задайте одно из двух при необходимости.
# Раскомментируйте и укажите путь, если HTTPS к OpenRouter/Qdrant падает с CERTIFICATE_VERIFY_FAILED.
# REQUESTS_CA_BUNDLE=C:/certs/corp-root.pem
# SSL_CERT_FILE=
