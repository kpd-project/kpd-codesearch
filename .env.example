# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WHITELIST_USERS=

# OpenRouter
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Embeddings (OpenRouter: openai/text-embedding-3-small)
EMBEDDINGS_MODEL=openai/text-embedding-3-small
EMBEDDINGS_DIMENSION=1536
# Макс. символов в одном API-запросе (~2k токенов по умолчанию)
EMBED_MAX_CHARS_PER_BATCH=8000

# Qdrant
QDRANT_URL=https://qdrant.gotskin.ru
QDRANT_API_KEY=
# Размер батча upsert (обход 413 nginx)
QDRANT_UPSERT_BATCH_SIZE=200

# Repos
REPOS_BASE_PATH=d:/kpd-project
REPOS_WHITELIST=kpd-backend,kpd-frontend,kpd-se,kpd-landing,kpd-pdf-2
