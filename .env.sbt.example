# ═══════════════════════════════════════════════════════════════════════════
# Пример окружения для корпоративного шлюза СБТ (api.ai.sbt) и Qdrant в docker-сети.
# Скопируйте в .env и подставьте реальный OPENAI_API_KEY.
# Все имена переменных — как в config.py; ниже сохранены рекомендованные для SBT значения
# (отличаются от дефолтов в коде там, где это задано явно).
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# LLM (OpenAI-compatible HTTP API)
# Формат ключа СБТ: email|JWT — см. документацию внутреннего API.
# ─────────────────────────────────────────────────────────────────────────────

OPENAI_BASE_URL=https://api.ai.sbt/openai/v1
OPENAI_API_KEY=user@yoursite.ru|eyJhbGciOiJIU...replace_with_real_token

# ─────────────────────────────────────────────────────────────────────────────
# EMBEDDINGS (Векторные представления)
# ─────────────────────────────────────────────────────────────────────────────

# Модель для создания эмбеддингов (тот же OpenAI-compatible endpoint)
# Рекомендуемые модели:
#   - openai/text-embedding-3-small (1536 размерность, дешёвый)
#   - openai/text-embedding-3-large (3072 размерность, качественнее)
#   - qwen/qwen3-embedding-8b (4096 размерность, open-source)
EMBEDDINGS_MODEL=Qodo/Qodo-Embed-1-1.5B

# Размерность векторов (должна совпадать с моделью!)
# text-embedding-3-small: 1536
# text-embedding-3-large: 3072
# qwen3-embedding-8b: 4096
EMBEDDINGS_DIMENSION=1536

# Макс. символов в одном батче для эмбеддингов (~4 символа ≈ 1 токен)
# Большие файлы разбиваются на батчи. Увеличьте для ускорения, уменьшите при 413 ошибках.
EMBED_MAX_CHARS_PER_BATCH=8000

# Макс. параллельных запросов к API эмбеддингов
# Увеличьте для ускорения индексации, уменьшите при rate limiting
EMBED_MAX_CONCURRENT=10

# Макс. параллельно обрабатываемых файлов
# Увеличьте для ускорения индексации на мощных серверах
EMBED_MAX_FILES_CONCURRENT=5

# Таймаут HTTP-запроса для эмбеддингов (секунды)
# Увеличьте при медленном интернете или больших файлах
EMBED_REQUEST_TIMEOUT=60

# ─────────────────────────────────────────────────────────────────────────────
# QDRANT (Векторная база данных)
# ─────────────────────────────────────────────────────────────────────────────

# URL Qdrant сервера
# Локально: http://localhost:6333
# Удалённо: https://your-qdrant-instance.com
QDRANT_URL=http://qdrant

# API ключ для Qdrant (если требуется аутентификация)
# Пустое значение = без аутентификации
QDRANT_API_KEY=root

# Размер батча для upsert в Qdrant
# Увеличьте для ускорения индексации, уменьшите при 413 ошибках от nginx
QDRANT_UPSERT_BATCH_SIZE=200

# ─────────────────────────────────────────────────────────────────────────────
# REPOSITORIES (Репозитории для индексации)
# ─────────────────────────────────────────────────────────────────────────────

# Базовый путь к репозиториям
# Пример: d:/projects или /home/user/projects
REPOS_BASE_PATH=~/sbt

# Список имён подпапок под REPOS_BASE_PATH через запятую (как в README; пусто = не задано в .env)
# REPOS_WHITELIST=

# Макс. размер файла в байтах (больше — плейсхолдер вместо содержимого)
# Превышение = файл индексируется как "слишком большой" без содержимого
FILE_MAX_SIZE=2000000

# ─────────────────────────────────────────────────────────────────────────────
# Режим RAG в чате (старт; в UI можно сменить) и simple: query rewriting
# ─────────────────────────────────────────────────────────────────────────────

RAG_RUNTIME_MODE=agent

# Модель для переписывания вопроса в simple-режиме (тот же OPENAI_BASE_URL).
# Если в каталоге СБТ нет gemini — укажите лёгкую быструю модель с того же шлюза.
SIMPLE_REWRITE_MODEL=google/gemini-2.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# RAG AGENT (Одноагентный режим - generator.py)
# Используется когда USE_TWO_AGENT_PIPELINE=false
# ─────────────────────────────────────────────────────────────────────────────

# Модель LLM для одноагентного режима
# Рекомендуемые модели:
#   - google/gemini-2.0-flash-001 (быстрый, дешёвый)
#   - google/gemini-2.5-flash-preview (баланс качества и скорости)
#   - openai/gpt-4o-mini (качественный, дороже)
OPENAI_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct

# Макс. итераций агентного цикла (поиск → LLM → tool_call → ...)
# Дефолт в коде: 10
RAG_AGENT_MAX_ITERATIONS=10

# Макс. символов чанка в ответе поиска (0 = целиком; иначе мягкая обрезка длинных файлов)
RAG_CHUNK_DISPLAY_CHARS=10000

# Топ-K результатов по умолчанию при поиске (шире — мягче отбор по объёму)
RAG_SEARCH_TOP_K=10

# Верхняя граница top_k (LLM не может запросить больше)
RAG_SEARCH_TOP_K_MAX=15

# Порог релевантности (score): ниже — больше кандидатов (мягче фильтр)
RAG_MIN_SCORE=0.45

# Макс. результатов при поиске по всем репо (объединённый топ)
# Ограничивает общее количество результатов из всех репозиториев
RAG_SEARCH_ALL_LIMIT=15

# max_tokens в цикле агента (с tool_calls; занижать нельзя — обрываются tool_calls)
RAG_AGENT_MAX_TOKENS=8000

# max_tokens для финального ответа (без инструментов)
RAG_AGENT_FINAL_MAX_TOKENS=3500

# temperature для LLM (0–1)
# 0 = детерминированно, 0.5 = баланс, 1 = креативно
# Рекомендуется 0.1-0.3 для кодовых вопросов
RAG_AGENT_TEMPERATURE=0.2

# Таймаут HTTP-запросов к LLM (секунды)
# Увеличьте при медленном интернете или сложных запросах
RAG_AGENT_TIMEOUT=60

# Длина превью результата tool_call в session log
# Для отладки: сколько символов логировать
RAG_LOG_RESULT_PREVIEW_LEN=300

# ─────────────────────────────────────────────────────────────────────────────
# TWO-AGENT PIPELINE (true = Analyst + Answerer; false = блок RAG AGENT выше)
# ─────────────────────────────────────────────────────────────────────────────

USE_TWO_AGENT_PIPELINE=true

# ─────────────────────────────────────────────────────────────────────────────
# ANALYST (Аналитик - планировщик поиска)
# Быстрая модель для анализа запроса и генерации поисковых запросов
# ─────────────────────────────────────────────────────────────────────────────

# Модель для Analyst (OpenAI-compatible endpoint)
# Рекомендуемые модели:
#   - openrouter/z-ai/glm-4-flash (быстрый, дешёвый)
#   - google/gemini-2.0-flash-001 (качественный)
ANALYST_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct

# temperature для Analyst (0–1)
# 0.1-0.3 = детерминированный анализ
# 0.4-0.6 = более вариативные поисковые запросы
ANALYST_TEMPERATURE=0.3

# max_tokens для Analyst (JSON; запас против обрезки ответа)
ANALYST_MAX_TOKENS=2000

# Таймаут для Analyst (секунды)
# Анализ обычно быстрый, но увеличьте при медленном API
ANALYST_TIMEOUT=60

# Макс. сообщений истории для Analyst
# Analyst видит последние N сообщений диалога
# Увеличьте для сохранения контекста длинных разговоров
ANALYST_HISTORY_LIMIT=20

# ─────────────────────────────────────────────────────────────────────────────
# ANSWERER (Эксперт - синтез ответа)
# Умная модель для осмысленного ответа пользователю
# ─────────────────────────────────────────────────────────────────────────────

# Модель для Answerer (OpenAI-compatible endpoint)
# Рекомендуемые модели:
#   - openrouter/z-ai/glm-4-plus (качественный, оптимальный баланс)
#   - google/gemini-2.5-pro-preview (максимальное качество)
#   - openai/gpt-4o (отличное качество, дороже)
ANSWERER_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct

# temperature для Answerer (0–1)
# 0.1-0.2 = детерминированные ответы (рекомендуется)
# 0.3-0.5 = более вариативные формулировки
ANSWERER_TEMPERATURE=0.1

# max_tokens для Answerer (развёрнутый ответ с кодом)
ANSWERER_MAX_TOKENS=4000

# Reasoning-модели: лимит «раздумий»; для обычных инструкт-моделей оставьте 0
ANSWERER_MAX_REASONING_TOKENS=0

# Таймаут для Answerer (секунды)
ANSWERER_TIMEOUT=120

# Макс. сообщений истории для Answerer
# Answerer видит последние N сообщений диалога
ANSWERER_HISTORY_LIMIT=20

# ─────────────────────────────────────────────────────────────────────────────
# PIPELINE (Настройки пайплайна)
# ─────────────────────────────────────────────────────────────────────────────

# Макс. итераций пайплайна (полный цикл за итерацию). 2–3 обычно хватает; 4 — тяжёлые кейсы
PIPELINE_MAX_ITERATIONS=3

# ─────────────────────────────────────────────────────────────────────────────
# DESCRIBER (автоописание репозитория: POST /api/repos/{name}/describe)
# Пустой DESCRIBER_MODEL = как ANALYST_MODEL
# ─────────────────────────────────────────────────────────────────────────────

DESCRIBER_MODEL=
DESCRIBER_MAX_ITERATIONS=12
DESCRIBER_MAX_TOKENS=8000
DESCRIBER_FINAL_MAX_TOKENS=2500
DESCRIBER_TEMPERATURE=0.2
DESCRIBER_TIMEOUT=60

# ─────────────────────────────────────────────────────────────────────────────
# Опционально: корпоративный TLS (см. также .env.example)
# ─────────────────────────────────────────────────────────────────────────────

# REQUESTS_CA_BUNDLE=
# SSL_CERT_FILE=
